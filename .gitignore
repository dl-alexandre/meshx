# The directory Mix will write compiled artifacts to.
/_build/
apps/*/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/
apps/*/cover/

# The directory Mix downloads your dependencies sources to.
/deps/
apps/*/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/
apps/*/doc/

# Temporary files, for example, from tests.
/tmp/
/var/

# Local SQLite runtime databases.
*.db
*.db-shm
*.db-wal

# Editor/cloud-sync backup copies.
*.bak
* 2.*

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump
apps/*/erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore Hex package tarballs built during local testing.
*.tar
.zig-cache/
apps/*/tmp_*
apps/*/priv/generated/
apps/*/priv/*.so
*.o
*.a

# Ad-hoc BLE capture sessions; checked-in fixtures live under apps/*/test/fixtures/captures/.
apps/*/priv/captures/

# Generated local-BLE run outputs (manifests, logs). Tests tagged
# :hardware_artifact reference 20 specific files under
# artifacts/local-ble/2026-05-17-sm-t577u-ipad9/ which are tracked
# explicitly (committed via `git add -f`) — they remain in the index
# regardless of this ignore. To add a new fixture file under here,
# use `git add -f <path>`.
/artifacts/local-ble/
apps/*/tmp/

# Android Gradle build artifacts
apps/*/android/build/
apps/*/android/.gradle/
apps/*/android/local.properties

# macOS Finder metadata
.DS_Store

# Local-only artifacts (Claude Code session state, agent research notes,
# scheduled task locks) — should never be committed.
.claude/

# iCloud Drive occasionally corrupts .git internals; rescue scripts move
# the broken state aside as .git.broken-*/ for forensics. Local only.
.git.broken-*/

# Built iOS app bundles (device/sim deploy output, ~hundreds of MB).
# Generated by `mix mob.node.deploy_device` / Xcode — never commit.
apps/*/ios/*.app/

# Generated Swift package scaffold (SPM Sources emitted during device builds).
apps/mob_node/Sources/

# Cursor editor workspace config (local only, like .claude/).
.cursor/
