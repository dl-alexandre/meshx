# 02-mob-static-nif-table.patch
#
# Registers meshx_ble_nif_nif_init in mob's erts_static_nif_tab so that
# the BEAM on iOS can resolve our extra statically-linked NIF when
# Elixir calls erlang:load_nif("meshx_ble_nif", _) at startup.
#
# Author: meshx project (in-tree patch)
# Authored against: mob 0.5.18
# Updated: 2026-05-16
# Tracked by: apps/meshx_mobile_app/lib/mix/tasks/meshx.patch_deps.ex
# Background: docs/BLE_BRIDGE.md § "Build system note", project memory
#             [[mob-dev-ios-build-vendored-patches]]
#
--- a/apps/meshx_mobile_app/deps/mob/ios/driver_tab_ios.c
+++ b/apps/meshx_mobile_app/deps/mob/ios/driver_tab_ios.c
@@ -46,6 +46,9 @@
 // generates function name: mob_nif_nif_init
 void *mob_nif_nif_init(void);
 
+// meshx_ble_nif.m's ERL_NIF_INIT(meshx_ble_nif, ...) with -DSTATIC_ERLANG_NIF
+void *meshx_ble_nif_nif_init(void);
+
 // exqlite sqlite3_nif is linked statically on device (pass -DMOB_STATIC_SQLITE_NIF
 // when compiling this file in device builds). On simulator it loads dynamically
 // as a .so and must NOT appear in the static table.
@@ -65,6 +68,7 @@
     {asn1rt_nif_nif_init,   1, THE_NON_VALUE, NULL},
     {crypto_nif_init,       1, THE_NON_VALUE, NULL},
     {mob_nif_nif_init,      0, THE_NON_VALUE, NULL},
+    {meshx_ble_nif_nif_init, 0, THE_NON_VALUE, NULL},
 #ifdef MOB_STATIC_SQLITE_NIF
     {sqlite3_nif_nif_init,  0, THE_NON_VALUE, NULL},
 #endif
